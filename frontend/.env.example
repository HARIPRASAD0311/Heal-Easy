# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables MUST start with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────

# AWS API Gateway base URL (no trailing slash)
# Format: https://<api-id>.execute-api.<region>.amazonaws.com/<stage>
VITE_API_BASE_URL=	https://86oc4w0vj5.execute-api.ap-south-1.amazonaws.com/prod


# Optional: override individual resource base paths if your API uses custom routes
VITE_API_AUTH_PATH=/auth
VITE_API_PATIENTS_PATH=/patients
VITE_API_DOCTORS_PATH=/doctors
VITE_API_CONSULTATIONS_PATH=/consultations
VITE_API_QUEUE_PATH=/queue
VITE_API_AI_PATH=/ai

# Request timeout in milliseconds (default: 15000)
VITE_API_TIMEOUT=15000

# App environment: development | staging | production
VITE_APP_ENV=development

# ─────────────────────────────────────────────────────────────────
# AWS Cognito (Amplify Authentication)
# Find these in AWS Console → Cognito → User Pools → your pool
# ─────────────────────────────────────────────────────────────────

# AWS region your Cognito User Pool is deployed in
VITE_AWS_REGION=ap-south-1

# Cognito User Pool ID  (format: <region>_XXXXXXXXX)
VITE_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX

# Cognito App Client ID  (find under User Pool → App clients)
VITE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────

# Identity Pool ID — only needed if using AWS credentials directly (e.g. S3 uploads)
# VITE_COGNITO_IDENTITY_POOL_ID=ap-south-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Cognito Hosted UI domain — only needed if using OAuth / social login
# VITE_COGNITO_DOMAIN=your-domain.auth.ap-south-1.amazoncognito.com

# OAuth redirect URLs (comma-separated for multiple, e.g. local + prod)
# VITE_COGNITO_REDIRECT_SIGN_IN=http://localhost:5173/,https://yourdomain.com/
# VITE_COGNITO_REDIRECT_SIGN_OUT=http://localhost:5173/login,https://yourdomain.com/login
